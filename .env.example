# =====================================================================
# Crypto Wallet Shorts pipeline — environment variables
# Copy this file to `.env` and fill in your real values.
# =====================================================================

# --- LLM (script + metadata generation) ----------------------------
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Data sources --------------------------------------------------
# Which upstream feed selects "interesting" wallets for the bot:
#   dune       – generic DEX traders from a saved Dune query
#   polymarket – top Polymarket users + their open prediction-market positions
DATA_SOURCE=polymarket

# Dune Analytics: https://dune.com/docs/api/
DUNE_API_KEY=your_dune_api_key
# Query ID from your saved query (e.g., 7363190)
DUNE_WALLET_QUERY_ID=7363190

# Arkham Intelligence
# (Public API access is gated; if you don't have it, leave the key blank
# and the pipeline will run on Dune data only.)
ARKHAM_API_KEY=
ARKHAM_BASE_URL=https://api.arkhamintelligence.com

# Polymarket leaderboard tuning (only used when DATA_SOURCE=polymarket)
POLYMARKET_WINDOW=Month                # Day | Week | Month | All
POLYMARKET_METRIC=profit               # profit | volume
POLYMARKET_LEADERBOARD_LIMIT=25        # how many top users to scan
POLYMARKET_POSITIONS_PER_USER=8        # how many open markets to narrate per user
POLYMARKET_MAX_WALLETS_WITH_POSITIONS=10 # stop after this many users with open positions (need a pool > daily videos for dedup)

# --- TTS -----------------------------------------------------------
# Provider: "gtts" (free) | "elevenlabs" | "openai"
# gtts uses Google Translate - completely free!
TTS_PROVIDER=gtts
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL=eleven_turbo_v2_5
OPENAI_API_KEY=
OPENAI_TTS_VOICE=onyx

# --- Image generation ----------------------------------------------
# Provider: "openai" | "stability" | "none" (none = solid-color background)
IMAGE_PROVIDER=openai
STABILITY_API_KEY=

# --- YouTube -------------------------------------------------------
YOUTUBE_CLIENT_SECRETS_FILE=credentials/client_secret.json
YOUTUBE_TOKEN_FILE=credentials/token.json
YOUTUBE_CATEGORY_ID=28           # 28=Science & Technology, 25=News & Politics
YOUTUBE_PRIVACY_STATUS=private   # private | unlisted | public
YOUTUBE_MADE_FOR_KIDS=false

# --- Filtering thresholds (cross-source consensus) -----------------
MIN_ROI_PERCENT=50.0
MIN_WINRATE=0.6
MIN_TRADES=20
CONSISTENCY_WINDOW_DAYS=90
MAX_WALLETS_PER_RUN=1

# --- Pipeline behavior ---------------------------------------------
# Cron firing schedule. Defaults to 4×/day; alt: "0 8,14,20 * * *" for 3×/day.
RUN_SCHEDULE_CRON=0 8,12,16,20 * * *
OUTPUT_DIR=./output
DRY_RUN=true                     # if true, skip the YouTube upload
LOG_LEVEL=INFO
TARGET_VIDEO_SECONDS=55          # hard ceiling, must stay under 60

# --- Deduplication (no repeated wallets / markets) -----------------
HISTORY_FILE=./output/history.json
WALLET_LOOKBACK_DAYS=14          # don't feature same wallet again within N days
POSITION_LOOKBACK_DAYS=3         # don't feature same open-positions set within N days

# --- Subtitles / Captions -----------------------------------------
# Burn the SRT into the frames? false = upload as YouTube caption tracks
# (real CC toggle + language picker, no on-screen clutter).
BURN_SUBTITLES=false
# Comma-separated lang codes. First one is the source (matches narration).
CAPTION_LANGUAGES=en,es,pt,hi,id

# --- Compliance ----------------------------------------------------
INCLUDE_DISCLAIMER=true
